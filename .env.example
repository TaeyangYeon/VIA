# VIA (Vision Intelligence Agent) 환경 변수 예시
# 이 파일을 .env로 복사하여 사용하세요: cp .env.example .env
# .env 파일은 .gitignore에 포함되어 있습니다 (커밋하지 마세요).

# ─────────────────────────────────────────────
# 백엔드 서버 설정
# ─────────────────────────────────────────────

# FastAPI 서버 바인딩 주소
# 로컬 개발: 0.0.0.0 (모든 인터페이스)
# 보안 환경: 127.0.0.1 (localhost만)
VIA_HOST=0.0.0.0

# FastAPI 서버 포트
# 기본값: 8000. 다른 서비스와 충돌 시 변경하세요.
VIA_PORT=8000

# 디버그 모드
# true: uvicorn 자동 리로드 활성화 (개발용)
# false: 프로덕션 모드 (패키징된 앱)
VIA_DEBUG=false

# ─────────────────────────────────────────────
# 파일 저장 설정
# ─────────────────────────────────────────────

# 업로드 이미지 저장 디렉토리
# 절대 경로 또는 프로젝트 루트 기준 상대 경로
VIA_UPLOAD_DIR=uploads

# ─────────────────────────────────────────────
# 로깅 설정
# ─────────────────────────────────────────────

# 로그 레벨
# DEBUG | INFO | WARNING | ERROR | CRITICAL
# 개발 시: DEBUG, 프로덕션 시: INFO
VIA_LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# AI 엔진 설정
# ─────────────────────────────────────────────

# AI 엔진 모드
# local  : 로컬 Ollama 사용 (기본값, 오프라인 가능)
# colab  : Google Colab GPU 원격 실행
# 앱 UI의 Engine Settings 패널에서도 변경 가능
VIA_ENGINE_MODE=local

# Google Colab 터널 URL
# VIA_ENGINE_MODE=colab 일 때 필요합니다.
# cloudflared 터널 URL 형식: https://xxxxx.trycloudflare.com
# 비어 있으면 Colab 모드로 전환 시 오류 발생
# Colab 설정 방법: docs/COLAB_GUIDE.md 참고
VIA_COLAB_URL=

# ─────────────────────────────────────────────
# 테스트 설정
# ─────────────────────────────────────────────

# E2E 통합 테스트용 Ollama URL
# 비통합 테스트에는 사용되지 않습니다.
# 로컬 실행: http://localhost:11434
# Colab 연결 시: https://xxxxx.trycloudflare.com
# 예시: VIA_OLLAMA_URL=https://abc123.trycloudflare.com python -m pytest tests/e2e/ -m "integration and e2e"
VIA_OLLAMA_URL=http://localhost:11434
